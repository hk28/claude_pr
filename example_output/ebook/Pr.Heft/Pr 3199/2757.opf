        <meta name="calibre:user_metadata:#readdate" content="{&quot;table&quot;: &quot;custom_column_15&quot;, &quot;column&quot;: &quot;value&quot;, &quot;datatype&quot;: &quot;datetime&quot;, &quot;is_multiple&quot;: null, &quot;kind&quot;: &quot;field&quot;, &quot;name&quot;: &quot;Gelesen am&quot;, &quot;search_terms&quot;: [&quot;#readdate&quot;], &quot;label&quot;: &quot;readdate&quot;, &quot;colnum&quot;: 15, &quot;display&quot;: {&quot;date_format&quot;: null}, &quot;is_custom&quot;: true, &quot;is_category&quot;: false, &quot;link_column&quot;: &quot;value&quot;, &quot;category_sort&quot;: &quot;value&quot;, &quot;is_csp&quot;: false, &quot;is_editable&quot;: true, &quot;rec_index&quot;: 34, &quot;#value#&quot;: null, &quot;#extra#&quot;: null, &quot;is_multiple2&quot;: {}}"/>
        <meta name="calibre:user_metadata:#special_title" content="{&quot;table&quot;: &quot;custom_column_14&quot;, &quot;column&quot;: &quot;value&quot;, &quot;datatype&quot;: &quot;composite&quot;, &quot;is_multiple&quot;: null, &quot;kind&quot;: &quot;field&quot;, &quot;name&quot;: &quot;Mein Titel&quot;, &quot;search_terms&quot;: [&quot;#special_title&quot;], &quot;label&quot;: &quot;special_title&quot;, &quot;colnum&quot;: 14, &quot;display&quot;: {&quot;composite_sort&quot;: &quot;text&quot;, &quot;composite_template&quot;: &quot;program:\n\tcheck_core = subitems(field('#core'), 1, 2);\n\tis_pr = strcmp(subitems(field('#core'), 0, 1), 'PR', '', 'PR', '');\n\tpr = test(is_pr, check_core, '');\n\tpr = strcat(pr, ' ', field('title'));\n#       compute the equivalent of the composite fields and store them in local variables\n    stripped = subitems(field('series'), -1, 0);\n#stripped = re(stripped, \&quot;.\&quot;, \&quot; \&quot;);\n#re(field('series'), '^(A|The|An)\\s+', '');\n    shortened = shorten(stripped, 4, '-' ,4);\n    initials = re(stripped, '[^\\w]*(\\w?)[^\\s]+(\\s|$)', '\\1');\n\n#       Format the series index. Ends up as empty if there is no series index.\n#       Note that leading and trailing spaces will be removed by the formatter,\n#       so we cannot add them here. We will do that in the strcat below.\n#       Also note that because we are in 'program' mode, we can freely use\n#       curly brackets in strings, something we cannot do in template mode.\n    s_index = template('{series_index:0&gt;2.1f}');\n\ttitle = field('title');\n#       print(stripped, shortened, initials, s_index);\n\n#       Now concatenate all the bits together. The switch picks between\n#       initials and shortened, depending on whether there is a space\n#       in stripped. We then add the brackets around s_index if it is\n#       not empty. Finally, add the title. As this is the last function in\n#       the program, its value will be returned.\n    s = strcat(\n        switch( stripped,\n                '.\\s', initials, \n                '.', shortened,\n                field('series')),\n        test(s_index, strcat(' [', s_index, '] '), ''),\n        title);\n\ttest(is_pr, pr, s)&quot;, &quot;use_decorations&quot;: 0, &quot;contains_html&quot;: false, &quot;make_category&quot;: false}, &quot;is_custom&quot;: true, &quot;is_category&quot;: false, &quot;link_column&quot;: &quot;value&quot;, &quot;category_sort&quot;: &quot;value&quot;, &quot;is_csp&quot;: false, &quot;is_editable&quot;: true, &quot;rec_index&quot;: 35, &quot;#value#&quot;: &quot;Heft 2757 - Das Sorgenkind&quot;, &quot;#extra#&quot;: null, &quot;is_multiple2&quot;: {}}"/>
        <meta name="calibre:user_metadata:#status" content="{&quot;table&quot;: &quot;custom_column_19&quot;, &quot;column&quot;: &quot;value&quot;, &quot;datatype&quot;: &quot;text&quot;, &quot;is_multiple&quot;: &quot;|&quot;, &quot;kind&quot;: &quot;field&quot;, &quot;name&quot;: &quot;Status&quot;, &quot;search_terms&quot;: [&quot;#status&quot;], &quot;label&quot;: &quot;status&quot;, &quot;colnum&quot;: 19, &quot;display&quot;: {&quot;is_names&quot;: false, &quot;description&quot;: &quot;&quot;}, &quot;is_custom&quot;: true, &quot;is_category&quot;: true, &quot;link_column&quot;: &quot;value&quot;, &quot;category_sort&quot;: &quot;value&quot;, &quot;is_csp&quot;: false, &quot;is_editable&quot;: true, &quot;rec_index&quot;: 36, &quot;#value#&quot;: [], &quot;#extra#&quot;: null, &quot;is_multiple2&quot;: {&quot;cache_to_list&quot;: &quot;|&quot;, &quot;ui_to_list&quot;: &quot;,&quot;, &quot;list_to_ui&quot;: &quot;, &quot;}}"/>
        <meta name="calibre:user_metadata:#t1" content="{&quot;table&quot;: &quot;custom_column_13&quot;, &quot;column&quot;: &quot;value&quot;, &quot;datatype&quot;: &quot;composite&quot;, &quot;is_multiple&quot;: null, &quot;kind&quot;: &quot;field&quot;, &quot;name&quot;: &quot;test1&quot;, &quot;search_terms&quot;: [&quot;#t1&quot;], &quot;label&quot;: &quot;t1&quot;, &quot;colnum&quot;: 13, &quot;display&quot;: {&quot;composite_sort&quot;: &quot;text&quot;, &quot;contains_html&quot;: false, &quot;use_decorations&quot;: 0, &quot;make_category&quot;: false, &quot;composite_template&quot;: &quot;program:\n\tcheck_core = subitems(field('#core'), 1, 2);\n\tis_pr = strcmp(subitems(field('#core'), 0, 1), 'PR', '', 'PR', '');\n\tpr = test(is_pr, check_core, '');\n\tpr = strcat('PR ', pr, ' - ', field('title'));\n\nprint(\&quot;**\&quot;, is_pr, check_core, pr);\n#       compute the equivalent of the composite fields and store them in local variables\n    stripped = subitems(field('series'), -1, 0);\n#stripped = re(stripped, \&quot;.\&quot;, \&quot; \&quot;);\n#re(field('series'), '^(A|The|An)\\s+', '');\n    shortened = shorten(stripped, 4, '-' ,4);\n    initials = re(stripped, '[^\\w]*(\\w?)[^\\s]+(\\s|$)', '\\1');\n\n#       Format the series index. Ends up as empty if there is no series index.\n#       Note that leading and trailing spaces will be removed by the formatter,\n#       so we cannot add them here. We will do that in the strcat below.\n#       Also note that because we are in 'program' mode, we can freely use\n#       curly brackets in strings, something we cannot do in template mode.\n    s_index = template('{series_index:0&gt;2.0f}');\n\ttitle = field('title');\n       print(stripped, shortened, initials, s_index);\n\n#       Now concatenate all the bits together. The switch picks between\n#       initials and shortened, depending on whether there is a space\n#       in stripped. We then add the brackets around s_index if it is\n#       not empty. Finally, add the title. As this is the last function in\n#       the program, its value will be returned.\n    s = strcat(\n        switch( stripped,\n                '.\\s', initials,\n                '.', shortened,\n                field('series')),\n        test(s_index, strcat(' [', s_index, '] '), ''),\n        title);\n\ttest(is_pr, pr, s)&quot;}, &quot;is_custom&quot;: true, &quot;is_category&quot;: false, &quot;link_column&quot;: &quot;value&quot;, &quot;category_sort&quot;: &quot;value&quot;, &quot;is_csp&quot;: false, &quot;is_editable&quot;: true, &quot;rec_index&quot;: 37, &quot;#value#&quot;: &quot;PR Heft - 2757 - Das Sorgenkind&quot;, &quot;#extra#&quot;: null, &quot;is_multiple2&quot;: {}}"/>
