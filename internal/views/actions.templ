package views

import (
	"fmt"
	"strings"

	"github.com/hk28/prman/internal/processor"
)

templ ScanPreview(report processor.ScanReport, errStr string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if errStr != "" {
			<div class="bg-[rgba(248,113,113,.08)] border border-[rgba(248,113,113,.25)] text-[#f87171] rounded-[7px] p-[10px_14px]">Error: { errStr }</div>
		} else {
			<h4 class="mb-3 text-[14px] font-bold">Scan Complete</h4>
			if len(report.ScannedDirs) > 0 {
				<div class="flex items-baseline gap-2 flex-wrap mb-2.5">
					<span class="text-[10px] font-bold uppercase tracking-[.08em] text-[#3a3a60]">Searched:</span>
					for _, d := range report.ScannedDirs {
						<code class="font-mono text-[12px] bg-[#18182a] px-[5px] py-px rounded-[4px] text-[#7878a8]">{ d }</code>
					}
				</div>
			}
			<p>Found <strong>{ fmt.Sprintf("%d", len(report.Found)) }</strong> inbox items, fetched metadata for <strong>{ fmt.Sprintf("%d", len(report.Fetched)) }</strong> new issues.</p>
			if len(report.Found) > 0 {
				<ul class="list-none p-0 mt-2.5 flex flex-col gap-1.5">
					for _, r := range report.Found {
						<li class="flex items-center gap-2 text-[13px]">
							<span class={ TypeTagClass(r.MediaType) }>{ r.MediaType }</span>
							#{ fmt.Sprintf("%d", r.Number) } — <code class="font-mono text-[12px] bg-[#18182a] px-[5px] py-px rounded-[4px] text-[#7878a8]">{ r.FolderPath }</code>
						</li>
					}
				</ul>
			}
			if len(report.Errors) > 0 {
				<div class="text-[#f87171] text-[13px] mt-2">
					<strong>Errors:</strong>
					<ul>
						for _, e := range report.Errors {
							<li>{ e }</li>
						}
					</ul>
				</div>
			}
		}
	</div>
}

templ UpdateAllResult(totalMarked int, errs []string) {
	<div id="update-all-result" class="px-3.5 py-2 text-[11px]">
		if len(errs) > 0 {
			<span class="text-[#f87171]">{ fmt.Sprintf("%d marked, %d error(s)", totalMarked, len(errs)) }</span>
		} else {
			<span class="text-[#34d399]">{ fmt.Sprintf("Updated — %d marked released", totalMarked) }</span>
		}
	</div>
}

templ UpdateResult(report processor.UpdateReport, errStr string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if errStr != "" {
			<div class="bg-[rgba(248,113,113,.08)] border border-[rgba(248,113,113,.25)] text-[#f87171] rounded-[7px] p-[10px_14px]">Error: { errStr }</div>
		} else {
			<h4 class="mb-3 text-[14px] font-bold">Update Complete</h4>
			<p>Latest issue: <strong>#{ fmt.Sprintf("%d", report.LatestIssue) }</strong>. Marked <strong>{ fmt.Sprintf("%d", report.MarkedCount) }</strong> issues as Released.</p>
			if len(report.Fetched) > 0 {
				<p>Auto-fetched metadata for <strong>{ fmt.Sprintf("%d", len(report.Fetched)) }</strong> new issue(s):
					for _, n := range report.Fetched {
						<span class={ BadgeOk }>{ "#" + fmt.Sprintf("%d", n) }</span>
					}
				</p>
			}
			if len(report.FetchErrors) > 0 {
				<div class="text-[#f87171] text-[13px] mt-2">
					<strong>Fetch errors:</strong>
					<ul>
						for _, e := range report.FetchErrors {
							<li>{ e }</li>
						}
					</ul>
				</div>
			}
		}
	</div>
}

templ RefreshResult(report processor.RefreshReport, errStr string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if errStr != "" {
			<div class="bg-[rgba(248,113,113,.08)] border border-[rgba(248,113,113,.25)] text-[#f87171] rounded-[7px] p-[10px_14px]">Error: { errStr }</div>
		} else {
			<h4 class="mb-3 text-[14px] font-bold">Metadata Updated</h4>
			<p>Refreshed <strong>{ fmt.Sprintf("%d", len(report.Fetched)) }</strong> issue(s).</p>
			if len(report.Errors) > 0 {
				<div class="text-[#f87171] text-[13px] mt-2">
					<strong>Errors:</strong>
					<ul>
						for _, e := range report.Errors {
							<li>{ e }</li>
						}
					</ul>
				</div>
			}
		}
	</div>
}

templ ClearCacheResult(slug string, errStr string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if errStr != "" {
			<div class="bg-[rgba(248,113,113,.08)] border border-[rgba(248,113,113,.25)] text-[#f87171] rounded-[7px] p-[10px_14px]">Error: { errStr }</div>
		} else {
			<h4 class="mb-3 text-[14px] font-bold">Cache Cleared</h4>
			<p>Metadata and cover images for <strong>{ slug }</strong> deleted. Use <em>Update Metadata</em> or <em>Scan Inbox</em> to re-fetch.</p>
		}
	</div>
}

templ CopyPreview(slug string, actions []processor.CopyAction, done []processor.CopyAction, errStr string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if errStr != "" {
			<div class="bg-[rgba(248,113,113,.08)] border border-[rgba(248,113,113,.25)] text-[#f87171] rounded-[7px] p-[10px_14px]">Error: { errStr }</div>
		} else {
			if len(actions) > 0 {
				<h4 class="mb-3 text-[14px] font-bold">Pending — { fmt.Sprintf("%d", len(actions)) } action(s)</h4>
				<table class="w-full border-collapse text-[12px] mt-2.5">
					<thead>
						<tr>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">#</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">Type</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">Source</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">Destination</th>
						</tr>
					</thead>
					<tbody>
						for _, a := range actions {
							<tr>
								<td class="p-[6px_10px] border-b border-white/[.07]">{ fmt.Sprintf("%d", a.Number) }</td>
								<td class="p-[6px_10px] border-b border-white/[.07]"><span class={ TypeTagClass(a.MediaType) }>{ a.MediaType }</span></td>
								<td class="p-[6px_10px] border-b border-white/[.07]"><code class="font-mono text-[11px] bg-[#18182a] px-[5px] py-px rounded-[4px] text-[#7878a8] break-all">{ a.SrcPath }</code></td>
								<td class="p-[6px_10px] border-b border-white/[.07]"><code class="font-mono text-[11px] bg-[#18182a] px-[5px] py-px rounded-[4px] text-[#7878a8] break-all">{ a.DstDir }/{ a.DstName }</code></td>
							</tr>
						}
					</tbody>
				</table>
				<div class="mt-3.5">
					<button
						class={ BtnDanger }
						hx-post={ "/series/" + slug + "/copy" }
						hx-target="#action-result"
						hx-swap="innerHTML"
						hx-confirm={ fmt.Sprintf("Copy %d item(s) to output?", len(actions)) }
					>Execute Copy</button>
				</div>
			} else {
				<p class="text-[#7878a8]">Nothing pending to copy.</p>
			}
			if len(done) > 0 {
				<h4 class="mt-4 mb-3 text-[14px] font-bold">Already copied — { fmt.Sprintf("%d", len(done)) } item(s)</h4>
				<table class="w-full border-collapse text-[12px] mt-2.5 opacity-60">
					<thead>
						<tr>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">#</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">Type</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">Source</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">Output</th>
						</tr>
					</thead>
					<tbody>
						for _, a := range done {
							<tr>
								<td class="p-[6px_10px] border-b border-white/[.07]">{ fmt.Sprintf("%d", a.Number) }</td>
								<td class="p-[6px_10px] border-b border-white/[.07]"><span class={ TypeTagClass(a.MediaType) }>{ a.MediaType }</span></td>
								<td class="p-[6px_10px] border-b border-white/[.07]"><code class="font-mono text-[11px] bg-[#18182a] px-[5px] py-px rounded-[4px] text-[#7878a8] break-all">{ a.SrcPath }</code></td>
								<td class="p-[6px_10px] border-b border-white/[.07]"><code class="font-mono text-[11px] bg-[#18182a] px-[5px] py-px rounded-[4px] text-[#7878a8] break-all">{ a.DstDir }</code></td>
							</tr>
						}
					</tbody>
				</table>
			}
		}
	</div>
}

templ CopyResult(count int, errors []string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if len(errors) > 0 {
			<div class="text-[#f87171] text-[13px] mb-2">
				<strong>{ fmt.Sprintf("%d", len(errors)) } error(s):</strong>
				<ul>
					for _, e := range errors {
						<li>{ e }</li>
					}
				</ul>
			</div>
		}
		<p>Successfully copied <strong>{ fmt.Sprintf("%d", count) }</strong> item(s).</p>
	</div>
}

templ PatchAudioMetadataPreview(slug string, report processor.PatchAudioMetadataReport, errStr string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if errStr != "" {
			<div class="bg-[rgba(248,113,113,.08)] border border-[rgba(248,113,113,.25)] text-[#f87171] rounded-[7px] p-[10px_14px]">Error: { errStr }</div>
		} else {
			{{ changed := 0 }}
			for _, a := range report.Actions {
				if a.Changed {
					{{ changed++ }}
				}
			}
			<h4 class="mb-3 text-[14px] font-bold">Fix Audio Series Tags — Preview</h4>
			if changed == 0 && len(report.Actions) == 0 {
				<p class="text-[#7878a8]">No audio output folders found.</p>
			} else if changed == 0 {
				<p class="text-[#7878a8]">All { fmt.Sprintf("%d", len(report.Actions)) } file(s) already up to date.</p>
			} else {
				<p class="mb-3"><strong>{ fmt.Sprintf("%d", changed) }</strong> of { fmt.Sprintf("%d", len(report.Actions)) } file(s) will be updated.</p>
				<table class="w-full border-collapse text-[12px]">
					<thead>
						<tr>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">#</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">Current series tags</th>
							<th class="text-left p-[6px_10px] text-[#7878a8] border-b border-white/[.07] text-[10px] uppercase tracking-[.07em]">New series tags</th>
						</tr>
					</thead>
					<tbody>
						for _, a := range report.Actions {
							if a.Changed {
								<tr>
									<td class="p-[6px_10px] border-b border-white/[.07] font-bold text-[#7c6ef7] tabular-nums">{ fmt.Sprintf("%d", a.Number) }</td>
									<td class="p-[6px_10px] border-b border-white/[.07] text-[#f87171]">{ strings.Join(a.OldSeries, " · ") }</td>
									<td class="p-[6px_10px] border-b border-white/[.07] text-[#4ade80]">{ strings.Join(a.NewSeries, " · ") }</td>
								</tr>
							}
						}
					</tbody>
				</table>
				<div class="mt-3.5">
					<button
						class={ BtnDanger }
						hx-post={ "/series/" + slug + "/patch-audio-metadata" }
						hx-target="#action-result"
						hx-swap="innerHTML"
						hx-confirm={ fmt.Sprintf("Update series tags in %d metadata.json file(s)?", changed) }
					>Apply</button>
				</div>
			}
			if len(report.Errors) > 0 {
				<div class="text-[#f87171] text-[13px] mt-3">
					<strong>Errors:</strong>
					<ul>
						for _, e := range report.Errors {
							<li>{ e }</li>
						}
					</ul>
				</div>
			}
		}
	</div>
}

templ PatchAudioMetadataResult(count int, errors []string) {
	<div class="bg-surface border border-white/[.07] rounded-xl p-[18px] mb-3">
		if len(errors) > 0 {
			<div class="text-[#f87171] text-[13px] mb-2">
				<strong>{ fmt.Sprintf("%d", len(errors)) } error(s):</strong>
				<ul>
					for _, e := range errors {
						<li>{ e }</li>
					}
				</ul>
			</div>
		}
		<p>Updated series tags in <strong>{ fmt.Sprintf("%d", count) }</strong> file(s).</p>
	</div>
}
