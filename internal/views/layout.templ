package views

templ Layout(vm PageVM) {
	<!DOCTYPE html>
	<html lang="de">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>prman — Perry Rhodan Manager</title>
			<script src="https://cdn.tailwindcss.com"></script>
			<script>
				tailwind.config = {
					theme: {
						extend: {
							colors: {
								surface: '#10101c',
								elevated: '#18182a',
								accent: { DEFAULT: '#7c6ef7', hover: '#9a8eff' },
								muted: '#7878a8',
								dim: '#3a3a60',
								audio: '#38bdf8',
								ebook: '#34d399',
								warn: '#fbbf24',
								danger: '#f87171',
								ok: '#34d399',
								done: '#818cf8',
							}
						}
					}
				}
			</script>
			<style>
				.htmx-indicator { display: none; }
				.htmx-request .htmx-indicator,
				.htmx-request.htmx-indicator { display: inline; }
				.view-btn { color: #7878a8; text-decoration: none; }
				.view-btn:hover { color: #eeeeff; }
				.view-btn.active { background-color: #7c6ef7; color: #fff; box-shadow: 0 1px 6px rgba(124,110,247,.25); }
				#cover-modal {
					border: none; padding: 0; background: transparent;
					width: 100vw; max-width: 100vw;
					height: 100vh; max-height: 100vh;
					position: fixed; inset: 0; margin: auto;
				}
				#cover-modal::backdrop { background: rgba(0,0,0,.88); cursor: pointer; backdrop-filter: blur(4px); }
			</style>
			<script src="/static/htmx.min.js" defer></script>
		</head>
		<body class="bg-[#080810] text-[#eeeeff] font-sans text-sm leading-normal antialiased h-full">
			<div class="grid h-screen overflow-hidden grid-cols-[228px_1fr]">
				<aside class="bg-surface border-r border-white/[.07] overflow-y-auto overflow-x-hidden [scrollbar-width:thin] [scrollbar-color:rgba(255,255,255,.07)_transparent]">
					@Sidebar(vm)
				</aside>
				<div class="grid overflow-hidden grid-rows-[54px_1fr]">
					@Topbar(vm)
					<main class="overflow-y-auto px-8 py-7 [scrollbar-width:thin]" id="main-content">
						{ children... }
					</main>
				</div>
			</div>
			<dialog id="cover-modal" onclick="if(event.target===this)this.close()">
				<div class="bg-surface border border-white/[.12] rounded-xl p-3.5 flex flex-col items-center gap-2.5 w-fit max-w-[95vw] max-h-[calc(100vh-40px)] mx-auto mt-5 shadow-[0_24px_80px_rgba(0,0,0,.6)]">
					<img id="cover-modal-img" src="" alt="Cover" class="flex-1 min-h-0 max-w-[min(600px,90vw)] max-h-[calc(100vh-100px)] w-auto h-auto object-contain rounded-[7px] block"/>
					<a id="cover-modal-src" href="#" target="_blank" rel="noopener" class="text-[12px] text-[#7c6ef7] hover:text-[#9a8eff]">↗ View on Perrypedia</a>
				</div>
			</dialog>
			<script>
				function openCover(localUrl, srcUrl) {
					var m = document.getElementById('cover-modal');
					document.getElementById('cover-modal-img').src = localUrl;
					var a = document.getElementById('cover-modal-src');
					a.href = srcUrl || '#'; a.style.display = srcUrl ? '' : 'none';
					m.showModal();
				}
				function syncViewButtons() {
					var view = new URLSearchParams(window.location.search).get('view') || 'medium';
					document.querySelectorAll('#topbar-views .view-btn').forEach(function(btn) {
						btn.classList.toggle('active', btn.dataset.view === view);
					});
				}
				document.addEventListener('htmx:afterSettle', syncViewButtons);
				function bindActionsPanel() {
					var toggle = document.getElementById('actions-toggle');
					var panel = document.getElementById('actions-panel');
					if (!toggle || !panel) return;
					toggle.onclick = function() {
						var closed = panel.classList.toggle('translate-x-full');
						toggle.style.right = closed ? '0' : '210px';
					};
				}
				document.addEventListener('htmx:afterSettle', bindActionsPanel);
				document.addEventListener('DOMContentLoaded', bindActionsPanel);
				document.addEventListener('click', function(e) {
					var el = e.target.closest('[data-cover-url]');
					if (el) openCover(el.getAttribute('data-cover-url'), el.getAttribute('data-source-url') || '');
				});
				(function() {
					var st = document.getElementById('sidebar-status');
					var timer;
					document.addEventListener('htmx:beforeRequest', function() {
						clearTimeout(timer);
						if (st) st.textContent = 'fetching…';
					});
					document.addEventListener('htmx:afterSettle', function() {
						clearTimeout(timer);
						if (st) { st.textContent = 'done'; timer = setTimeout(function() { st.textContent = ''; }, 2000); }
					});
					document.addEventListener('htmx:responseError', function() {
						clearTimeout(timer);
						if (st) { st.textContent = 'error'; timer = setTimeout(function() { st.textContent = ''; }, 4000); }
					});
				})();
			</script>
		</body>
	</html>
}
