package views

templ IndexPage(vm PageVM) {
	@Layout(vm) {
		@MainContent(vm)
	}
}

templ MainContent(vm PageVM) {
	switch vm.ViewMode {
		case "big":
			<div class="flex flex-wrap gap-[18px] items-start">
				for _, s := range vm.Series {
					if (vm.FilterSlug == "" || vm.FilterSlug == s.Config.SlugName) && (vm.FilterType == "" || HasType(s.Config.Types, vm.FilterType)) {
						@CardBig(s)
					}
				}
			</div>
		case "medium":
			<div class="flex flex-wrap gap-[18px] items-start">
				for _, s := range vm.Series {
					if (vm.FilterSlug == "" || vm.FilterSlug == s.Config.SlugName) && (vm.FilterType == "" || HasType(s.Config.Types, vm.FilterType)) {
						@CardMedium(s)
					}
				}
			</div>
		default:
			for _, s := range vm.Series {
				if (vm.FilterSlug == "" || vm.FilterSlug == s.Config.SlugName) && (vm.FilterType == "" || HasType(s.Config.Types, vm.FilterType)) {
					@SeriesDetail(s)
				}
			}
	}
}
